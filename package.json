{
  "name": "glancething",
  "version": "0.0.16",
  "description": "Desktop application for GlanceThing",
  "main": "./out/main/index.js",
  "author": "BluDood",
  "homepage": "https://github.com/BluDood/GlanceThing",
  "scripts": {
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:win:nightly": "npm run build && electron-builder --win --config electron-builder.nightly.yml",
    "build:mac:nightly": "npm run build && electron-builder --mac --config electron-builder.nightly.yml",
    "build:linux:nightly": "npm run build && electron-builder --linux --config electron-builder.nightly.yml"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource/material-icons": "^5.2.7",
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "moment": "^2.30.1",
    "node-cron": "^4.2.1",
    "party-js": "^2.2.0",
    "react-router-dom": "^7.13.1",
    "totp-generator": "^2.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^25.4.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typed-emitter": "^2.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "optionalDependencies": {
    "node-nowplaying-darwin-universal": "0.1.0",
    "node-nowplaying-linux-x64-gnu": "0.1.0",
    "node-nowplaying-win32-x64-msvc": "0.1.0"
  }
}
